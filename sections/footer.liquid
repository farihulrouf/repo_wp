<footer class="bg-[#0F0F0F] border-t border-[#262626] pt-20 pb-10">
    <div class="max-w-[1440px] 2xl:max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-12 gap-12 mb-20">
            <div class="lg:col-span-4">
                <div class="flex items-center gap-2 mb-8">
                    <div class="w-10 h-10 purple-gradient rounded-lg flex items-center justify-center">
                        <div class="w-5 h-5 bg-white rounded-full"></div>
                    </div>
                    <span class="text-xl font-bold tracking-tight">{{ shop.name }}</span>
                </div>
                <div class="relative max-w-sm">
                    {% form 'customer', class: 'relative' %}
                        <input type="email" name="contact[email]" placeholder="Enter Your Email" class="w-full h-14 pl-6 pr-14 bg-transparent border border-[#262626] rounded-xl focus:outline-none focus:border-[#703BF7]">
                        <button type="submit" class="absolute right-2 top-2 h-10 w-10 flex items-center justify-center text-[#999999] hover:text-white">
                            <i data-lucide="send" class="w-5 h-5"></i>
                        </button>
                    {% endform %}
                </div>
            </div>
            
            <div class="lg:col-span-8 grid grid-cols-2 md:grid-cols-4 gap-8">
                {% if section.blocks.size > 0 %}
                    {% for block in section.blocks %}
                    <div {{ block.shopify_attributes }}>
                        <h4 class="text-[#999999] font-medium mb-6">{{ block.settings.title }}</h4>
                        <ul class="space-y-4 text-sm">
                            {% for link in block.settings.menu.links %}
                            <li><a href="{{ link.url }}" class="hover:text-[#703BF7]">{{ link.title }}</a></li>
                            {% endfor %}
                        </ul>
                    </div>
                    {% endfor %}
                {% else %}
                    <!-- Fallback if no blocks added -->
                    <div>
                        <h4 class="text-[#999999] font-medium mb-6">Quick Links</h4>
                        <p class="text-xs text-[#555]">Add menus in Theme Editor</p>
                    </div>
                {% endif %}
            </div>
        </div>
        
        <div class="flex flex-col md:flex-row justify-between items-center gap-6 pt-10 border-t border-[#262626]">
            <div class="flex gap-8 text-sm text-[#999999]">
                <span>&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All Rights Reserved.</span>
                {% if section.settings.terms_link != blank %}
                <a href="{{ section.settings.terms_link }}" class="hover:text-white">Terms & Conditions</a>
                {% endif %}
            </div>
            <div class="flex gap-4">
                {% if settings.social_facebook_link != blank %}
                <a href="{{ settings.social_facebook_link }}" class="w-10 h-10 rounded-full border border-[#262626] flex items-center justify-center hover:bg-[#703BF7] hover:text-white transition-all">
                    <i data-lucide="facebook" class="w-5 h-5"></i>
                </a>
                {% endif %}
                {% if settings.social_twitter_link != blank %}
                <a href="{{ settings.social_twitter_link }}" class="w-10 h-10 rounded-full border border-[#262626] flex items-center justify-center hover:bg-[#703BF7] hover:text-white transition-all">
                    <i data-lucide="twitter" class="w-5 h-5"></i>
                </a>
                {% endif %}
                {% if settings.social_linkedin_link != blank %}
                <a href="{{ settings.social_linkedin_link }}" class="w-10 h-10 rounded-full border border-[#262626] flex items-center justify-center hover:bg-[#703BF7] hover:text-white transition-all">
                    <i data-lucide="linkedin" class="w-5 h-5"></i>
                </a>
                {% endif %}
            </div>
        </div>
    </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "url",
      "id": "terms_link",
      "label": "Terms & Conditions Link"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
